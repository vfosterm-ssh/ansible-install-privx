# yamllint configuration
---
extends: default

# Ignore certain files
ignore: |
  .yamllint
  .github/workflows/*

rules:
  line-length:
    max: 350  # Allow longer lines for complex Jinja2 expressions
    level: warning  # Make it a warning instead of error

  comments:
    min-spaces-from-content: 1

  comments-indentation: false  # Required by ansible-lint

  indentation:
    spaces: 2
    indent-sequences: true

  truthy:
    allowed-values: ['true', 'false', 'yes', 'no']

  braces:
    max-spaces-inside: 1  # Required by ansible-lint

  octal-values:
    forbid-implicit-octal: true   # Required by ansible-lint
    forbid-explicit-octal: true   # Required by ansible-lint
